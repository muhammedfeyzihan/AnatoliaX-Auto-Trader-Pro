# ============================================================
# AnatoliaX Environment Variables v2.0
# Bu dosyayi .env olarak kopyalayin ve gercek degerleri girin.
# .env GitHub'a ASLA yuklenmez (K137).
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Data Sources (K91-K92)
TRADINGVIEW_API_KEY=
INVESTING_API_KEY=

# Broker API (K129)
BROKER_TYPE=mock
BROKER_API_KEY=
BROKER_SECRET=
MATRIKS_WS_URL=wss://api.matriksdata.com/ws
MATRIKS_REST_URL=https://api.matriksdata.com/rest
MATRIKS_API_KEY=
IDEALFX_URL=https://api.idealfx.com.tr/v1
IDEALFX_API_KEY=
FOREKS_WS_URL=wss://api.foreks.com/ws
FOREKS_REST_URL=https://api.foreks.com/rest
FOREKS_API_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anatoliax
SQLITE_PATH=./data/anatoliax.db

# ChromaDB
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
DATA_DIR=./data

# System (K122-K140)
AX_TELEGRAM_ENABLED=true
AX_TELEGRAM_BOTTOKEN=
AX_TELEGRAM_CHATID=
AX_LOGGING_LEVEL=info
AX_DATA_PRIMARYSOURCE=tradingview
AX_RISK_MAXPOSITIONPERSTOCK=0.02
AX_RISK_MAXDAILYLOSS=0.03
AX_RISK_MAXCORRELATION=0.80
AX_RISK_MAXPOSITIONS=5
AX_SCALPING_INDEX=BIST100
AX_SLIPPAGE_BASERATE=0.001
AX_SLIPPAGE_MAXRATE=0.01
AX_COMMISSION_RATE=0.001
AX_BSMV_RATE=0.001
AX_HEALTHCHECK_INTERVAL=60

# ============================================================
# Paper Trading (v2.1)
# ============================================================
AX_PAPER_TRADING=true
AX_PAPER_INITIAL_CAPITAL=100000
AX_PAPER_MAX_POSITIONS=5
AX_PAPER_MAX_RISK_PCT=10

# ============================================================
# Data Sources (v2.1 - Ucretsiz)
# ============================================================
AX_DATA_PRIMARY=yahoo
AX_DATA_SECONDARY=investing
AX_DATA_TERTIARY=bigpara
AX_DATA_CACHE_TTL=3600

# ============================================================
# Forward Test (v2.1)
# ============================================================
AX_FORWARD_TEST_ENABLED=true
AX_FORWARD_TEST_LOOKAHEAD_DAYS=5

# ============================================================
# Telegram Reporting (v2.1)
# ============================================================
AX_TELEGRAM_REPORT_MORNING=true
AX_TELEGRAM_REPORT_EVENING=true

# ============================================================
# Nautilus Trader (v3.1 - Opsiyonel)
# ============================================================
NAUTILUS_LIVE=false

# ============================================================
# gRPC TLS (v3.1 - Opsiyonel, localhost icin gerekmez)
# ============================================================
GRPC_TLS_CERT=
GRPC_TLS_KEY=

# ============================================================
# Macro Placeholder Overrides (v3.1)
# ============================================================
TCMB_RATE=50.0
TUFe_RATE=0.0
