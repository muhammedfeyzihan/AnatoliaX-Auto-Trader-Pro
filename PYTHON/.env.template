# =============================================================================
# ANATOLIAX AUTO-TRADER - ENVIRONMENT CONFIGURATION TEMPLATE
# K254: Tüm yapılandırma startup'ta Pydantic ile validate edilmelidir
# =============================================================================

# -----------------------------------------------------------------------------
# CORE SYSTEM SETTINGS
# -----------------------------------------------------------------------------
ANATOLIAX_ENV=production  # development, staging, production
ANATOLIAX_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
ANATOLIAX_VERSION=3.5.0

# -----------------------------------------------------------------------------
# PERFORMANCE & RESOURCE OPTIMIZATION
# -----------------------------------------------------------------------------
# CPU/Memory
MAX_WORKERS=auto  # auto = CPU count - 1, or specify number
USE_PROCESS_POOL=false  # true for CPU-bound, false for I/O-bound (Windows: false recommended)
MEMORY_LIMIT_GB=8  # Maximum memory usage in GB
ENABLE_NUMA_AWARE=true  # NUMA node awareness for multi-socket systems
GC_THRESHOLD=700  # Python GC threshold (default: 700)

# Caching
CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=512  # LRU cache max size
CACHE_TTL_SECONDS=300  # Default cache time-to-live
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=60  # Redis cache TTL in seconds

# Database
DB_TYPE=postgresql  # postgresql, questdb, sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=anatoliax
DB_USER=anatoliax_user
DB_PASSWORD=CHANGE_ME_SECRET
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30
DB_STATEMENT_TIMEOUT=30000  # milliseconds

# QuestDB (Time-series)
QUESTDB_ENABLED=true
QUESTDB_HOST=localhost
QUESTDB_PORT=9009
QUESTDB_USER=admin
QUESTDB_PASSWORD=CHANGE_ME_SECRET
QUESTDB_DB_PATH=./questdb_data

# -----------------------------------------------------------------------------
# MARKET DATA & TRADING
# -----------------------------------------------------------------------------
# Market Data Feeds
MARKET_DATA_PROVIDER=binance  # binance, yahoo, polygon, custom
MARKET_DATA_WS_URL=wss://stream.binance.com:9443/ws
MARKET_DATA_HTTP_URL=https://api.binance.com
MARKET_DATA_API_KEY=CHANGE_ME_SECRET
MARKET_DATA_API_SECRET=CHANGE_ME_SECRET

# Broker/Exchange
BROKER_TYPE=paper  # paper, interactive, alpaca, binance
BROKER_API_KEY=CHANGE_ME_SECRET
BROKER_API_SECRET=CHANGE_ME_SECRET
BROKER_ACCOUNT_ID=

# Trading Parameters
DEFAULT_CAPITAL=1000000  # Starting capital in TRY/USD
MAX_POSITION_PCT=0.02  # Max 2% per position
MAX_DAILY_DD=0.05  # Max 5% daily drawdown
MAX_CONCURRENT_POSITIONS=10
COMMISSION_RATE=0.001  # 0.1% commission
SLIPPAGE_MODEL=default  # default, aggressive, conservative

# Order Execution
ORDER_TIMEOUT_MS=5000  # Order timeout in milliseconds
ORDER_MAX_RETRIES=3
ORDER_BACKOFF_MS=100  # Initial backoff between retries
ENABLE_SHADOW_EXECUTION=true  # Shadow mode for validation
ENABLE_SMART_ORDER_ROUTING=true
ENABLE_TOXIC_FLOW_DETECTION=true

# -----------------------------------------------------------------------------
# RISK MANAGEMENT
# -----------------------------------------------------------------------------
RISK_ENGINE_ENABLED=true
RISK_MAX_GROSS_EXPOSURE=1.5  # 150% of capital
RISK_MAX_NET_EXPOSURE=0.8  # 80% of capital
RISK_MAX_SECTOR_EXPOSURE=0.20  # 20% per sector
RISK_MAX_BETA=1.5  # Max portfolio beta
RISK_VAR_CONFIDENCE=0.99  # 99% VaR confidence
RISK_CVAR_MULTIPLIER=1.5  # CVaR multiplier
RISK_KILL_SWITCH_DD=0.10  # 10% drawdown triggers kill switch
RISK_ALPHA_DECAY_ENABLED=true
RISK_SHARPE_THRESHOLD=0.5  # Min Sharpe ratio to continue trading

# -----------------------------------------------------------------------------
# AGENT SYSTEM (Multi-Agent AI)
# -----------------------------------------------------------------------------
AGENT_COUNCIL_ENABLED=true
AGENT_CONSENSUS_TYPE=simple_majority  # simple_majority, super_majority, unanimous
AGENT_TRUST_SCORER_ENABLED=true
AGENT_MANIPULATION_DETECTION=true
AGENT_REGIME_DETECTION=true
AGENT_REGIME_MODEL=online  # online, offline, hybrid

# AI/ML Models
AI_MODEL_PROVIDER=ollama  # ollama, openai, anthropic, local
AI_MODEL_NAME=llama3.1:8b
AI_MODEL_ENDPOINT=http://localhost:11434
AI_MODEL_API_KEY=
AI_MODEL_TEMPERATURE=0.1  # Lower = more deterministic
AI_MODEL_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# OBSERVABILITY & MONITORING
# -----------------------------------------------------------------------------
# Logging
LOG_FORMAT=json  # json, text
LOG_FILE=./logs/anatoliax.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true

# Metrics (Prometheus)
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_PUSHGATEWAY_URL=

# Tracing (OpenTelemetry)
TRACING_ENABLED=true
TRACING_EXPORTER=jaeger  # jaeger, zipkin, otlp, console
TRACING_ENDPOINT=http://localhost:14268/api/traces
TRACING_SAMPLE_RATE=1.0  # 1.0 = 100% sampling

# Alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=
ALERT_SMTP_SERVER=
ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK=
ALERT_TELEGRAM_ENABLED=true
ALERT_TELEGRAM_BOT_TOKEN=CHANGE_ME_SECRET
ALERT_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# NETWORK & LATENCY OPTIMIZATION
# -----------------------------------------------------------------------------
# Colocation
COLOCATION_ENABLED=true
COLOCATION_REGION=IST  # IST, LON, NYC, TYO
COLOCATION_PREFER_LOW_LATENCY=true

# TCP Tuning
TCP_KEEPALIVE=true
TCP_KEEPALIVE_IDLE=60  # seconds
TCP_KEEPALIVE_INTERVAL=10  # seconds
TCP_KEEPALIVE_COUNT=6
TCP_NODELAY=true  # Disable Nagle's algorithm
TCP_SEND_BUFFER_SIZE=262144  # 256KB
TCP_RECV_BUFFER_SIZE=262144  # 256KB

# Connection Pooling
HTTP_POOL_MAX_SIZE=100
HTTP_POOL_MAX_KEEPALIVE=30  # seconds
WS_RECONNECT_DELAY=5  # seconds
WS_MAX_RECONNECT=10

# DNS
DNS_CACHE_TTL=300  # seconds
DNS_CACHE_ENABLED=true

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Encryption
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_KEY=CHANGE_ME_SECRET_32_BYTES
ENCRYPTION_KEY_ROTATION_DAYS=90

# Authentication
AUTH_ENABLED=true
AUTH_TOKEN_EXPIRY_HOURS=24
AUTH_REFRESH_TOKEN_EXPIRY_DAYS=7
AUTH_JWT_SECRET=CHANGE_ME_SECRET_JWT

# Access Control
RBAC_ENABLED=true
RBAC_DEFAULT_ROLE=trader  # admin, trader, readonly

# Audit
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=./logs/audit.log
AUDIT_LOG_IMMUTABLE=true

# -----------------------------------------------------------------------------
# MLOPS & MODEL GOVERNANCE
# -----------------------------------------------------------------------------
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=anatoliax_production

DVC_ENABLED=false
DVC_REMOTE_URL=s3://anatoliax-dvc-data

MODEL_REGISTRY_PATH=./models/registry
MODEL_VALIDATION_ENABLED=true
MODEL_DRIFT_THRESHOLD=0.1  # Drift detection threshold

# -----------------------------------------------------------------------------
# HARDWARE ACCELERATION (Optional)
# -----------------------------------------------------------------------------
GPU_ACCELERATION_ENABLED=false
GPU_DEVICE=0  # CUDA device ID
FPGA_ACCELERATION_ENABLED=false
FPGA_DEVICE=/dev/fpga0

# OpenCL
OPENCL_ENABLED=false
OPENCL_PLATFORM_ID=0
OPENCL_DEVICE_ID=0

# -----------------------------------------------------------------------------
# STRATEGY CONFIGURATION
# -----------------------------------------------------------------------------
ACTIVE_STRATEGIES=institutional_flow,gold_mining  # Comma-separated list
STRATEGY_RELOAD_INTERVAL_MIN=5
STRATEGY_ENSEMBLE_ENABLED=true
STRATEGY_ENSEMBLE_VOTING=weighted  # weighted, majority

# Gold Mining Strategy
GOLD_MINING_ENABLED=true
GOLD_MINING_TIERS=PCT_5,PCT_10,PCT_20
GOLD_MINING_MAX_POSITIONS_PER_TIER=5

# Protocol Strategies
PROTOCOL_STRATEGY_ENABLED=true
PROTOCOL_COMPOUND_GROWTH=true
PROTOCOL_TIERED_GROWTH=true

# -----------------------------------------------------------------------------
# BACKTEST & SIMULATION
# -----------------------------------------------------------------------------
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_BENCHMARK=THYAO
BACKTEST_SEED=42  # For reproducibility
BACKTEST_DETERMINISTIC=true

# Tick Simulator
TICK_SIM_LATENCY_MODEL=lognormal
TICK_SIM_SPREAD_MODEL=stress
TICK_SIM_SLIPPAGE_ALPHA1=0.5
TICK_SIM_SLIPPAGE_ALPHA2=0.3
TICK_SIM_SLIPPAGE_ALPHA3=0.2

# -----------------------------------------------------------------------------
# TELEGRAM BOT
# -----------------------------------------------------------------------------
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=CHANGE_ME_SECRET
TELEGRAM_ADMIN_IDS=123456789,987654321  # Comma-separated

# -----------------------------------------------------------------------------
# FEATURE FLAGS (A/B Testing)
# -----------------------------------------------------------------------------
FEATURE_NEW_RISK_ENGINE=true
FEATURE_AI_SIGNALS=true
FEATURE_SHADOW_MODE=true
FEATURE_AUTO_HEDGING=false
